# Create an Asana MCP app at https://app.asana.com/0/my-apps
ASANA_CLIENT_ID=
ASANA_CLIENT_SECRET=

# OpenAI Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6

# Must exactly match the redirect URL configured for the Asana MCP app.
ASANA_OAUTH_CALLBACK_HOST=127.0.0.1
ASANA_OAUTH_CALLBACK_PORT=3334
ASANA_OAUTH_CALLBACK_PATH=/oauth/callback

# AWS Read-only access
AWS_ACCESS_KEY=
AWS_ACCESS_KEY_SECRET=
# Optional comma-separated override. Empty means discover enabled regions.
AWS_REGIONS=

# Notion
NOTION_ACCESS_TOKEN=

# Ontix runtime
ONTIX_DATA_DIR=.data
ONTIX_ORGANIZATION_ID=departure
ONTIX_USER_ID=art-bradshaw
ONTIX_MAX_TOOL_ROUNDS=6
ONTIX_TOOL_TIMEOUT_MS=60000
ONTIX_MAX_EVIDENCE_CHARS=40000

# Optional. When absent, a mode-0600 local encryption key is generated under .data.
ONTIX_TOKEN_ENCRYPTION_KEY=
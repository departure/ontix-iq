{
  "name": "ontix-iq",
  "version": "0.1.0",
  "description": "Agentic executive intelligence for DEPARTURE",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.4.0"
  },
  "scripts": {
    "auth:asana": "tsx src/cli/auth-asana.ts",
    "build": "tsc -p tsconfig.build.json",
    "dev": "node --experimental-ffi --import tsx src/index.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "lint": "eslint .",
    "setup": "tsx src/cli/setup.ts",
    "start": "node --experimental-ffi dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/departure/ontix-iq.git"
  },
  "keywords": [
    "executive-intelligence",
    "agent",
    "terminal"
  ],
  "author": "DEPARTURE",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/departure/ontix-iq/issues"
  },
  "homepage": "https://github.com/departure/ontix-iq#readme",
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1092.0",
    "@aws-sdk/client-cost-explorer": "^3.1092.0",
    "@aws-sdk/client-ec2": "^3.1092.0",
    "@aws-sdk/client-rds": "^3.1092.0",
    "@aws-sdk/client-s3": "^3.1092.0",
    "@aws-sdk/client-sts": "^3.1092.0",
    "@aws-sdk/client-wafv2": "^3.1092.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^5.23.2",
    "@opentui/core": "^0.4.5",
    "dotenv": "^17.4.2",
    "openai": "^6.48.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@hono/node-server": "^2.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
